# DeepSeek uses an OpenAI-compatible API.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional. SAM.gov is not required for the first DataSF path.
SAM_API_KEY=

# Local runtime defaults.
PROJECTINTEL_DB_PATH=data/projectintel.sqlite3
PROJECTINTEL_CACHE_DIR=.cache/projectintel
PROJECTINTEL_USER_AGENT=BayAreaProjectIntel/0.1 (contact: you@example.com)
PROJECTINTEL_CSLB_MASTER_CSV=.cache/projectintel/cslb/MasterLicenseData.csv
PROJECTINTEL_LATEST_EXCEL_PATH=data/latest-leads.xlsx
PROJECTINTEL_NOTIFY_LOG_PATH=data/notify.log
PROJECTINTEL_DEFAULT_LOOKBACK_DAYS=60

# Email delivery: auto-send the leads Excel via SMTP (`projectintel email`).
# Defaults target Gmail over SSL (465). PROJECTINTEL_SMTP_PASSWORD must be a Gmail
# App Password (https://myaccount.google.com/apppasswords) — NOT your account
# password. EMAIL_TO is comma-separated for multiple recipients.
PROJECTINTEL_SMTP_HOST=smtp.gmail.com
PROJECTINTEL_SMTP_PORT=465
PROJECTINTEL_SMTP_USE_SSL=true
PROJECTINTEL_SMTP_USER=
PROJECTINTEL_SMTP_PASSWORD=
PROJECTINTEL_EMAIL_FROM=
PROJECTINTEL_EMAIL_TO=

# Tunables (all optional; shown with their defaults).
# Compliance: min seconds between requests to the same domain.
PROJECTINTEL_POLITENESS_MIN_INTERVAL=0.35
# Cross-source dedupe cutoffs (rapidfuzz token_set_ratio, 0-100). Higher = stricter.
PROJECTINTEL_DEDUPE_ADDRESS_THRESHOLD=92
PROJECTINTEL_DEDUPE_TITLE_THRESHOLD=72
# Public-web enrichment discovery/crawl caps.
PROJECTINTEL_WEB_MAX_DISCOVERY_CANDIDATES=6
PROJECTINTEL_WEB_MAX_CONTACT_LINKS=4
PROJECTINTEL_WEB_MIN_DISCOVERY_TOKEN_LEN=4
# Browser enrichment: max pages rendered per company.
PROJECTINTEL_BROWSER_MAX_PAGES=4
